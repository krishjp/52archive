{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@52archive/core": ["packages/core/src/index.ts"],
      "@52archive/core/*": ["packages/core/src/*"],
      "@52archive/ui": ["packages/ui/src/index.ts"],
      "@52archive/ui/*": ["packages/ui/src/*"]
    }
  }
}
